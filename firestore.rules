rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() && hasUserData() && getUserData().role == 'admin';
    }

    function isTeacher() {
      return isAuthenticated() && hasUserData() && (getUserData().role == 'teacher' || getUserData().role == 'admin');
    }

    function isApproved() {
      return isAuthenticated() && hasUserData() && (getUserData().approved == true || getUserData().role == 'teacher' || getUserData().role == 'admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isTeacher());
      allow delete: if isTeacher();
    }

    // --- Requests ---
    match /requests/{requestId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher();
    }

    // --- Messages ---
    match /messages/{messageId} {
      allow read: if isApproved() && (
        isTeacher() || 
        (resource.data.type == 'subject' && resource.data.section == getUserData().section) || 
        (resource.data.type == 'pm' && request.auth.uid in resource.data.participants)
      );
      allow create: if isApproved() && request.resource.data.senderId == request.auth.uid && (
        isTeacher() ||
        (request.resource.data.type == 'subject' && request.resource.data.section == getUserData().section) ||
        (request.resource.data.type == 'pm' && request.auth.uid in request.resource.data.participants)
      );
      allow update, delete: if isTeacher() || (isApproved() && resource.data.senderId == request.auth.uid);
    }

    // --- Grades ---
    match /grades/{gradeId} {
      allow read: if isApproved() && (isTeacher() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isTeacher();
    }

    // --- Attendance ---
    match /attendance/{attendanceId} {
      allow read: if isApproved() && (isTeacher() || resource.data.section == getUserData().section);
      allow create, update, delete: if isTeacher();
    }
  }
}
